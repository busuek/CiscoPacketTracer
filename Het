 no shutdown
 exit

! Настройка BGP
router bgp 101
 bgp log-neighbor-changes
 neighbor 10.0.0.5 remote-as 100
 neighbor 10.0.0.10 remote-as 103
 network 192.168.1.0 mask 255.255.255.0
 exit

! Статический маршрут для анонса агрегированной сети
ip route 192.168.1.0 255.255.255.0 Null0

! Распространение маршрута по умолчанию внутри AS 101 через RIP
router rip
 default-information originate
 exit

end
